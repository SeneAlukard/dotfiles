version = 2
console_title_template = "{{if .Root}}(Admin) {{end}}{{.Folder}}"
schema = "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json"

[[blocks]]
type = "prompt"
alignment = "left"

  [[blocks.segments]]
  type = "root"
  background = "#f1184c"
  foreground = "#242424"
  powerline_symbol = ""
  style = "powerline"
  template = ""

  [[blocks.segments]]
  type = "os"
  background = "#282c34"
  foreground = "#3A86FF"
  leading_diamond = " "
  style = "diamond"
  template = " {{ if .WSL }}WSL at {{ end }}{{.Icon}} "

  [[blocks.segments]]
  type = "time"
  background = "#242424"
  foreground = "#FFBB00"
  powerline_symbol = ""
  style = "powerline"
  template = "{{ .CurrentDate | date .Format }} "
  [blocks.segments.properties]
  time_format = "15:04:05"

  [[blocks.segments]]
  type = "path"
  background = "#242424"
  foreground = "#33DD2D"
  powerline_symbol = ""
  style = "powerline"
  template = " {{ .Path }} "
  [blocks.segments.properties]
  folder_separator_icon = "/"
  style = "folder"

  [[blocks.segments]]
  type = "git"
  background = "#242424"
  foreground = "#3A86FF"
  powerline_symbol = ""
  style = "powerline"
  template = "{{ .UpstreamIcon }}{{ .HEAD }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} "
  [blocks.segments.properties]
  fetch_stash_count = true
  fetch_status = true
  fetch_upstream_icon = true

  [[blocks.segments]]
  type = "dotnet"
  background = "#0184bc"
  foreground = "#ffffff"
  powerline_symbol = ""
  style = "powerline"
  template = "  {{ if .Unsupported }}{{ else }}{{ .Full }}{{ end }} "

  [[blocks.segments]]
  type = "executiontime"
  background = "#8800dd"
  foreground = "#ffffff"
  powerline_symbol = ""
  style = "powerline"
  template = " <#fefefe></> {{ .FormattedMs }} "
  [blocks.segments.properties]
  style = "austin"
  threshold = 1

  [[blocks.segments]]
  type = "status"
  background = "#33DD2D"
  foreground = "#242424"
  powerline_symbol = ""
  style = "powerline"
  template = "  "
  background_templates = ["{{ if gt .Code 0 }}#f1184c{{ end }}"]

[[blocks]]
type = "prompt"
alignment = "left"
newline = true

  [[blocks.segments]]
  type = "text"
  foreground = "#f1184c"
  style = "plain"
  template = "➜ "

